{
  "name": "@andreywtf/react-native-link-presentation",
  "version": "0.1.1",
  "description": "React Native bindings for Apple's LinkPresentation framework",
  "author": {
    "name": "Andrey Artamonychev",
    "email": "me@andrey.wtf"
  },
  "homepage": "https://github.com/qweritos/react-native-link-presentation",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qweritos/react-native-link-presentation.git"
  },
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.tsx",
  "source": "src/index.tsx",
  "files": [
    "src",
    "lib",
    "docs",
    "ios",
    "react-native-link-presentation.podspec",
    "!ios/RNLinkPresentationTests"
  ],
  "scripts": {
    "build": "bob build",
    "clean": "bob clean",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "pod:lint": "pod lib lint react-native-link-presentation.podspec --quick --platforms=ios",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"__tests__/**/*.{ts,tsx}\" \"*.{js,json,md}\" \".github/**/*.yml\" \"example/App.tsx\"",
    "prepare": "bob build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.76"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.0.0",
    "@react-native/babel-preset": "^0.86.0",
    "@react-native/eslint-config": "^0.86.0",
    "@react-native/jest-preset": "^0.86.0",
    "@react-native/metro-config": "^0.86.0",
    "@react-native/typescript-config": "^0.86.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "react": "^19.2.0",
    "react-native": "^0.86.0",
    "react-native-builder-bob": "^0.43.0",
    "typescript": "^5.8.3"
  },
  "codegenConfig": {
    "name": "RNLinkPresentationSpec",
    "type": "all",
    "jsSrcsDir": "src",
    "ios": {
      "modulesProvider": {
        "RNLinkPresentation": "RNLinkPresentation"
      },
      "componentProvider": {
        "RNLPLinkView": "RNLPLinkViewComponentView"
      }
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "jest": {
    "preset": "@react-native/jest-preset",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/example/",
      "/lib/"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
